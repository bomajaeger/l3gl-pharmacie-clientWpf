<UserControl x:Class="PharmacieApp.Views.MedicamentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============ Formulaire ============ -->
        <Border Grid.Column="0" Background="White" Padding="18" CornerRadius="6"
                BorderBrush="{StaticResource BrushBordure}" BorderThickness="1"
                Margin="0,0,12,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{Binding TitreFormulaire}" Style="{StaticResource SousTitre}" />

                    <TextBlock Text="Nom *" Style="{StaticResource Libelle}" />
                    <TextBox Style="{StaticResource ChampSaisie}"
                             Text="{Binding Nom, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Description" Style="{StaticResource Libelle}" />
                    <TextBox Style="{StaticResource ChampSaisieMultiligne}"
                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Prix (FCFA) *" Style="{StaticResource Libelle}" />
                    <TextBox Style="{StaticResource ChampSaisie}"
                             Text="{Binding Prix, UpdateSourceTrigger=PropertyChanged}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stock *" Style="{StaticResource Libelle}" />
                            <TextBox Style="{StaticResource ChampSaisie}"
                                     Text="{Binding QuantiteStock, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Seuil alerte *" Style="{StaticResource Libelle}" />
                            <TextBox Style="{StaticResource ChampSaisie}"
                                     Text="{Binding SeuilAlerte, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Date de péremption *" Style="{StaticResource Libelle}" />
                    <DatePicker Style="{StaticResource ChampDate}"
                                SelectedDate="{Binding DatePeremption}" />

                    <TextBlock Text="Fournisseur" Style="{StaticResource Libelle}" />
                    <ComboBox Style="{StaticResource ChampListe}"
                              ItemsSource="{Binding Fournisseurs}"
                              SelectedItem="{Binding FournisseurSelectionne}"
                              DisplayMemberPath="Nom" />

                    <WrapPanel Margin="0,18,0,0">
                        <Button Content="Ajouter"   Style="{StaticResource BoutonPrimaire}"
                                Command="{Binding AjouterCommand}" />
                        <Button Content="Modifier"  Style="{StaticResource BoutonPrimaire}"
                                Command="{Binding ModifierCommand}" />
                        <Button Content="Supprimer" Style="{StaticResource BoutonDanger}"
                                Command="{Binding SupprimerCommand}" />
                        <Button Content="Effacer"   Style="{StaticResource BoutonSecondaire}"
                                Command="{Binding EffacerCommand}" />
                    </WrapPanel>

                    <TextBlock Text="{Binding MessageErreur}" Style="{StaticResource MessageErreur}" />

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ============ Liste ============ -->
        <DockPanel Grid.Column="1">

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox Style="{StaticResource ChampSaisie}" Width="240"
                         Text="{Binding Recherche, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Rechercher" Style="{StaticResource BoutonPrimaire}"
                        Command="{Binding RechercherCommand}" Margin="8,4,8,4"
                        IsDefault="True" />
                <Button Content="Tout afficher" Style="{StaticResource BoutonSecondaire}"
                        Command="{Binding ChargerCommand}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <Border Background="{StaticResource BrushAlerteFond}" Width="16" Height="16"
                        BorderBrush="{StaticResource BrushBordure}" BorderThickness="1" />
                <TextBlock Text="Stock bas ou péremption proche" Margin="6,0,18,0"
                           Foreground="{StaticResource BrushTexteSecondaire}" FontSize="12" />
                <Border Background="{StaticResource BrushPerimeFond}" Width="16" Height="16"
                        BorderBrush="{StaticResource BrushBordure}" BorderThickness="1" />
                <TextBlock Text="Périmé" Margin="6,0,0,0"
                           Foreground="{StaticResource BrushTexteSecondaire}" FontSize="12" />
            </StackPanel>

            <DataGrid Style="{StaticResource GrilleDonnees}"
                      ItemsSource="{Binding Medicaments}"
                      SelectedItem="{Binding Selection}">

                <!-- Coloration des lignes selon les flags calculés par l'API.
                     L'ordre compte : le dernier DataTrigger vrai l'emporte,
                     donc "périmé" prime sur "en alerte". -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EnAlerteStock}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushAlerteFond}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EnAlertePeremption}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushAlerteFond}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EstPerime}" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushPerimeFond}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushDanger}" />
                            </DataTrigger>

                            <!-- La sélection par défaut peint un fond opaque qui
                                 masquerait la couleur d'alerte. On la remplace par
                                 une bordure gauche marquée, sans toucher au fond. -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaire}" />
                                <Setter Property="BorderThickness" Value="4,0,0,0" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Resources>
                    <!-- Neutralise le surlignage bleu/gris système, qui
                         recouvrirait les couleurs d'alerte des lignes. -->
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                     Color="Transparent" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                     Color="Transparent" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                     Color="{StaticResource ColorTexte}" />
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="2*" />
                    <DataGridTextColumn Header="Prix" Width="Auto"
                                        Binding="{Binding Prix, Converter={StaticResource Fcfa}}" />
                    <DataGridTextColumn Header="Stock" Binding="{Binding QuantiteStock}" Width="Auto" />
                    <DataGridTextColumn Header="Seuil" Binding="{Binding SeuilAlerte}" Width="Auto" />
                    <DataGridTextColumn Header="Péremption" Width="Auto"
                                        Binding="{Binding DatePeremption, StringFormat=dd/MM/yyyy}" />
                    <DataGridTextColumn Header="Fournisseur" Binding="{Binding FournisseurNom}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

        </DockPanel>
    </Grid>
</UserControl>