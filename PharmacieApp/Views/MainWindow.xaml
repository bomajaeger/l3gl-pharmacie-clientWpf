<Window x:Class="PharmacieApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PharmacieApp.Views"
        Title="Gestion de Pharmacie"
        Height="700" Width="1150"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Fichier">
                <MenuItem Header="_Déconnexion" Command="{Binding DeconnexionCommand}" />
                <Separator />
                <MenuItem Header="_Quitter" Command="{Binding QuitterCommand}" />
            </MenuItem>
            <MenuItem Header="_Aide">
                <MenuItem Header="À _propos" Click="MenuAPropos_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource BrushPrimaireClair}">
            <StatusBarItem>
                <TextBlock Text="{Binding Statut}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding NomUtilisateur, StringFormat='Connecté : {0}'}"
                           Foreground="{StaticResource BrushTexteSecondaire}" />
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="12" Background="Transparent" BorderThickness="0">

            <TabItem Header="Médicaments">
                <views:MedicamentsView />
            </TabItem>

            <TabItem Header="Fournisseurs">
                <views:FournisseursView />
            </TabItem>

            <TabItem Header="Ventes">
                <TextBlock Text="VentesView (étape 6.6)"
                           Margin="20" Foreground="{StaticResource BrushTexteSecondaire}" />
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>