<Window x:Class="PharmacieApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion — Big Pharma"
        Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border Background="White" Margin="18" Padding="28"
            BorderBrush="{StaticResource BrushBordure}" BorderThickness="1"
            CornerRadius="6">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Big Pharma"
                       Style="{StaticResource TitrePage}"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Identifiant" Style="{StaticResource Libelle}" />
            <TextBox x:Name="ChampIdentifiant"
                     Style="{StaticResource ChampSaisie}"
                     Text="{Binding NomUtilisateur, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Mot de passe" Style="{StaticResource Libelle}" />
            <PasswordBox x:Name="ChampMotDePasse"
                         Style="{StaticResource ChampMotDePasse}" />

            <Button Content="Se connecter"
                    Style="{StaticResource BoutonPrimaire}"
                    Margin="0,22,0,0"
                    IsDefault="True"
                    Command="{Binding ConnexionCommand}"
                    CommandParameter="{Binding ElementName=ChampMotDePasse}" />

            <TextBlock Text="Connexion en cours…"
                       Foreground="{StaticResource BrushTexteSecondaire}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EstOccupe}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding MessageErreur}"
                       Style="{StaticResource MessageErreur}"
                       HorizontalAlignment="Center" />

        </StackPanel>
    </Border>
</Window>